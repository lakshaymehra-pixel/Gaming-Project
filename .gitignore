// Unity generated — never commit these
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

// Asset Store / package caches
[Aa]ssets/AssetStoreTools*
[Aa]ssets/Plugins/Editor/JetBrains*

// Visual Studio / Rider / VS Code
.vs/
.idea/
.vscode/
*.csproj
*.unityproj
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

// Build artifacts
*.apk
*.aab
*.unitypackage
*.app
ExportedObj/
crashlytics-build.properties

// OS
.DS_Store
Thumbs.db
desktop.ini

// Keystores — NEVER commit signing keys
*.keystore
*.jks

// Firebase config. Ties this repo to one Firebase project and carries its API keys — the
// Android/iOS ones are not secret in the way a server key is (they ship inside every APK),
// but they identify and bill a specific project, and a public repo invites strangers to
// point their builds at it. Each developer downloads their own from the Firebase console.
[Aa]ssets/google-services.json
[Aa]ssets/GoogleService-Info.plist

// Firebase SDK — hundreds of MB of vendored binaries, and it is a download, not our source.
[Aa]ssets/Firebase/
[Aa]ssets/Firebase.meta
[Aa]ssets/ExternalDependencyManager/
[Aa]ssets/ExternalDependencyManager.meta
[Aa]ssets/Plugins/Android/*.aar
[Aa]ssets/Plugins/iOS/Firebase*
